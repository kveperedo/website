{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "react", "import", "promise"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "curly": ["error", "all"],
    "typescript/array-type": ["error", { "default": "generic" }]
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": ["src/routeTree.gen.ts"]
}
